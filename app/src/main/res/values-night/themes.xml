<?xml version="1.0" encoding="utf-8"?>
<!--
  Esta app esta disenada para modo claro (todos los layouts tienen fondos #FFFFFF
  y textos #1A1A1A hardcodeados). Para que la apariencia sea consistente cuando el
  sistema esta en modo oscuro, definimos AQUI el mismo Theme.AlarmaApp con los
  mismos colores que el tema claro de values/themes.xml. Asi Android no aplica
  un tema oscuro por su cuenta y todo se ve igual independientemente del modo.

  Si en el futuro quieres soportar modo oscuro de verdad, cambia los colores de
  abajo y reemplaza los #FFFFFF / #1A1A1A hardcodeados de los layouts por
  ?attr/colorSurface / ?attr/colorOnSurface.
-->
<resources>
    <style name="Theme.AlarmaApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#1A73E8</item>
        <item name="colorPrimaryVariant">#1557B0</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <item name="colorSecondary">#1A73E8</item>
        <item name="colorSecondaryVariant">#1557B0</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <item name="android:colorBackground">#FFFFFF</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnBackground">#1A1A1A</item>
        <item name="colorOnSurface">#1A1A1A</item>
    </style>
</resources>
