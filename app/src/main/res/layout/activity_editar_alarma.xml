<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Editar Alarma"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOMBRE"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre de la alarma"
                android:inputType="text"/>

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UBICACIÓN"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <Button
            android:id="@+id/btnAbrirMapa"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"
            android:text="Cambiar ubicación"
            android:textColor="#1A73E8"
            android:backgroundTint="#F0F4FF"
            android:gravity="center"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RADIO DE ACTIVACIÓN (metros)"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRadio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="100"
                android:inputType="number"/>

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REPETICIÓN"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <Button
            android:id="@+id/btnRepeticion"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"
            android:text="Repetición"
            android:textColor="#1A73E8"
            android:backgroundTint="#F0F4FF"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONTACTOS"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <Button
            android:id="@+id/btnContactos"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"
            android:text="Gestionar contactos"
            android:textColor="#1A73E8"
            android:backgroundTint="#F0F4FF"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CATEGORÍA"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerCategoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOTA"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Aparecerá al activarse la alarma"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top|start"/>

        </com.google.android.material.textfield.TextInputLayout>


        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Guardar cambios"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A73E8"
            style="@style/Widget.MaterialComponents.Button"/>

        <Button
            android:id="@+id/btnCancelar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Cancelar"
            android:textColor="#888888"
            android:backgroundTint="#F5F5F5"
            style="@style/Widget.MaterialComponents.Button"/>

        <Button
            android:id="@+id/btnEliminar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Eliminar alarma"
            android:textColor="#D32F2F"
            android:backgroundTint="#FFF0F0"
            style="@style/Widget.MaterialComponents.Button"/>



    </LinearLayout>
</ScrollView>